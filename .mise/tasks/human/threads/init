#!/usr/bin/env bash
#MISE description="Initialize HUMAN.md from template"
#USAGE flag "--force" help="Overwrite header only in existing HUMAN.md"
set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SHIMMER_DIR="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
TEMPLATE_FILE="$SHIMMER_DIR/templates/HUMAN.md"

# Resolve HUMAN.md path via home delegation
HUMAN_PATH=$("$SHIMMER_DIR/.mise/tasks/_get-human-path")

if [ ! -f "$TEMPLATE_FILE" ]; then
  echo "Error: template not found at $TEMPLATE_FILE" >&2
  exit 1
fi

MARKER="--- HEADER END ---"

if [ -f "$HUMAN_PATH" ]; then
  if [ "${usage_force:-}" != "true" ]; then
    echo "HUMAN.md already exists at $HUMAN_PATH" >&2
    echo "Use --force to update the header only (threads are preserved)." >&2
    exit 1
  fi

  # Force mode: replace header, keep threads
  TEMPLATE_CONTENT=$(cat "$TEMPLATE_FILE")
  EXISTING_CONTENT=$(cat "$HUMAN_PATH")

  # Extract template header (everything up to and including the marker)
  if ! echo "$TEMPLATE_CONTENT" | grep -Fq -- "$MARKER"; then
    echo "Error: template missing '$MARKER'" >&2
    exit 1
  fi
  NEW_HEADER=$(echo "$TEMPLATE_CONTENT" | sed -n "1,/$MARKER/p")

  # Extract existing body (everything after the marker)
  if echo "$EXISTING_CONTENT" | grep -Fq -- "$MARKER"; then
    EXISTING_BODY=$(echo "$EXISTING_CONTENT" | sed "1,/$MARKER/d")
  else
    # No marker in existing file — treat entire content as body
    EXISTING_BODY=$'\n'"$EXISTING_CONTENT"
  fi

  printf '%s%s' "$NEW_HEADER" "$EXISTING_BODY" > "$HUMAN_PATH"
  echo "Updated header in $HUMAN_PATH (threads preserved)."
else
  # Fresh init
  mkdir -p "$(dirname "$HUMAN_PATH")"
  cp "$TEMPLATE_FILE" "$HUMAN_PATH"
  echo "Initialized HUMAN.md at $HUMAN_PATH"
fi
