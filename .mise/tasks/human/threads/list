#!/usr/bin/env bash
#MISE description="List HUMAN.md threads with status and who's waiting"
set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SHIMMER_DIR="$(cd "$SCRIPT_DIR/../../../.." && pwd)"

HUMAN_PATH=$("$SHIMMER_DIR/.mise/tasks/_get-human-path")

if [ ! -f "$HUMAN_PATH" ]; then
  echo "No HUMAN.md found at $HUMAN_PATH — run: shimmer human:threads:init" >&2
  exit 1
fi

output=$(HUMAN_PATH="$HUMAN_PATH" PYTHONPATH="$SHIMMER_DIR/lib" python3 << 'PYEOF'
import os
from human_threads import (
    split_header_body, parse_threads, extract_thread_body,
    extract_authors, extract_all_participants, extract_thread_starter,
    thread_title, thread_waiting_on,
)

content = open(os.environ["HUMAN_PATH"]).read()
header, body = split_header_body(content)
_, threads = parse_threads(body)

if not threads:
    print("NO_THREADS")
else:
    # Participants column encodes roles: + = started thread, * = last sender
    print("\t".join([" ", "Thread", "Participants", "Waiting on"]))
    for kind, lines in threads:
        title = thread_title(lines[0])
        body_lines = extract_thread_body(lines)
        authors = extract_authors(body_lines)
        participants = extract_all_participants(body_lines)
        starter = extract_thread_starter(body_lines)
        last_author = authors[-1] if authors else None
        waiting = thread_waiting_on(kind, authors)

        # Annotate: + for starter, * for last sender
        # For resolved threads, * naturally indicates who resolved it
        # (convention: resolving agent writes their summary last)
        annotated = []
        for name in participants:
            suffix = ""
            if name == starter:
                suffix += "+"
            if name == last_author:
                suffix += "*"
            annotated.append(name + suffix)

        if kind == "warning":
            status = "\U0001f448"
        elif kind == "success":
            status = "\u2713"
        else:
            status = " "

        print("\t".join([
            status,
            title,
            ", ".join(annotated) if annotated else "\u2014",
            waiting,
        ]))
PYEOF
)

if [ "$output" = "NO_THREADS" ]; then
  gum style --faint "No threads found in HUMAN.md"
else
  echo "$output" | gum table --print --separator "	" --border rounded \
    --border.foreground 240 --header.foreground 81
  gum style --faint "  + started thread  * last sender"
fi
