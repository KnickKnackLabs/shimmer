#!/usr/bin/env bash
#MISE description="Quick summary of HUMAN.md thread counts by status"
set -eo pipefail

HUMAN_PATH=$("$MISE_PROJECT_ROOT/.mise/tasks/_get-human-path")

if [ ! -f "$HUMAN_PATH" ]; then
  echo "No HUMAN.md found at $HUMAN_PATH — run: shimmer human:threads:init" >&2
  exit 1
fi

HUMAN_PATH="$HUMAN_PATH" PYTHONPATH="$MISE_PROJECT_ROOT/lib" python3 << 'PYEOF'
import os
from human_threads import (
    split_header_body, parse_threads, extract_thread_body,
    extract_message_senders, thread_waiting_on,
)

content = open(os.environ["HUMAN_PATH"]).read()
_, body = split_header_body(content)
_, threads = parse_threads(body)

counts = {"agent": 0, "or": 0, "resolved": 0, "unknown": 0}

for kind, lines in threads:
    if kind == "success":
        counts["resolved"] += 1
        continue

    body_lines = extract_thread_body(lines)
    senders = extract_message_senders(body_lines)
    waiting = thread_waiting_on(kind, senders)

    if waiting == "agent":
        counts["agent"] += 1
    elif waiting == "Or":
        counts["or"] += 1
    elif waiting == "resolved":
        counts["resolved"] += 1
    else:
        counts["unknown"] += 1

parts = []
if counts["agent"] > 0:
    parts.append(f'{counts["agent"]} waiting on agent')
if counts["or"] > 0:
    parts.append(f'{counts["or"]} waiting on Or')
if counts["resolved"] > 0:
    parts.append(f'{counts["resolved"]} resolved')
if counts["unknown"] > 0:
    parts.append(f'{counts["unknown"]} no messages')

total = sum(counts.values())
print(f"{total} threads: {', '.join(parts)}")
PYEOF
