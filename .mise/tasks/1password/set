#!/usr/bin/env bash
#MISE description="Store a secret in 1Password"
#USAGE arg "<agent>" help="Agent name (e.g., zeke, baby-joel)"
#USAGE arg "<key>" help="Secret key (e.g., github-pat, gpg-private-key, email-password)"
#USAGE flag "-v --value <value>" help="Value to store (or pipe via stdin)"

set -eo pipefail

AGENT="${usage_agent:-${1:?Usage: 1password:set <agent> <key>}}"
KEY="${usage_key:-${2:?Usage: 1password:set <agent> <key>}}"
VALUE="${usage_value:-}"

if ! command -v op &>/dev/null; then
  echo "ERROR: 1Password CLI (op) not found." >&2
  echo "       Install from: https://developer.1password.com/docs/cli" >&2
  exit 1
fi

if ! op account get &>/dev/null; then
  echo "ERROR: Not signed in to 1Password. Run: op signin" >&2
  exit 1
fi

# Read from stdin if no --value provided
if [ -z "$VALUE" ]; then
  if [ -t 0 ]; then
    echo "ERROR: No value provided. Use --value or pipe via stdin." >&2
    exit 1
  fi
  VALUE=$(cat)
fi

if [ -z "$VALUE" ]; then
  echo "ERROR: Empty value." >&2
  exit 1
fi

VAULT="Agents"

case "$KEY" in
  github-pat)
    ITEM="${AGENT} - GitHub"; FIELD="PAT[password]" ;;
  github-password)
    ITEM="${AGENT} - GitHub"; FIELD="password" ;;
  gpg-private-key)
    ITEM="${AGENT} - GPG"; FIELD="Private Key[text]" ;;
  gpg-public-key)
    ITEM="${AGENT} - GPG"; FIELD="Public Key[text]" ;;
  gpg-key-id)
    ITEM="${AGENT} - GPG"; FIELD="Key ID[text]" ;;
  gpg-fingerprint)
    ITEM="${AGENT} - GPG"; FIELD="Fingerprint[text]" ;;
  email-password)
    ITEM="${AGENT} - Email"; FIELD="password" ;;
  matrix-password)
    ITEM="${AGENT} - Matrix"; FIELD="password" ;;
  passphrase)
    ITEM="${AGENT} - Identity"; FIELD="passphrase[password]" ;;
  *)
    echo "ERROR: Unknown key: $KEY" >&2
    echo "       Known keys: github-pat, github-password, gpg-private-key, gpg-public-key," >&2
    echo "                   gpg-key-id, gpg-fingerprint, email-password, matrix-password, passphrase" >&2
    exit 1
    ;;
esac

op item edit "$ITEM" --vault "$VAULT" "${FIELD}=${VALUE}" >/dev/null 2>&1 || {
  echo "ERROR: Could not update key=$KEY for agent=$AGENT in 1Password" >&2
  echo "       Item: $ITEM / Field: $FIELD" >&2
  exit 1
}

echo "Stored: agent=$AGENT key=$KEY (1Password: $ITEM)"
