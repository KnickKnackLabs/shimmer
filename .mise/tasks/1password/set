#!/usr/bin/env bash
#MISE description="Store a secret in 1Password (creates item if it doesn't exist)"
#USAGE arg "<agent>" help="Agent name (e.g., zeke, baby-joel)"
#USAGE arg "<key>" help="Secret key (e.g., github-pat, gpg-private-key, email-password)"
#USAGE flag "-v --value <value>" help="Value to store (or pipe via stdin)"

set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../_secret-keys"

AGENT="${usage_agent:-${1:?Usage: 1password:set <agent> <key>}}"
KEY="${usage_key:-${2:?Usage: 1password:set <agent> <key>}}"
VALUE="${usage_value:-}"

if ! command -v op &>/dev/null; then
  echo "ERROR: 1Password CLI (op) not found." >&2
  echo "       Install from: https://developer.1password.com/docs/cli" >&2
  exit 1
fi

if ! op account get &>/dev/null; then
  echo "ERROR: Not signed in to 1Password. Run: op signin" >&2
  exit 1
fi

# Read from stdin if no --value provided
if [ -z "$VALUE" ]; then
  if [ -t 0 ]; then
    echo "ERROR: No value provided. Use --value or pipe via stdin." >&2
    exit 1
  fi
  VALUE=$(cat)
fi

if [ -z "$VALUE" ]; then
  echo "ERROR: Empty value." >&2
  exit 1
fi

if ! resolve_key "$KEY"; then
  echo "ERROR: Unknown key: $KEY" >&2
  echo "       Known keys: $(print_known_keys)" >&2
  exit 1
fi

VAULT="Agents"
ITEM="${AGENT} - ${OP_ITEM_SUFFIX}"

# Try edit first (item exists); fall back to create (item doesn't exist)
if op item get "$ITEM" --vault "$VAULT" </dev/null &>/dev/null; then
  # Item exists — edit the field
  op item edit "$ITEM" --vault "$VAULT" "${OP_FIELD_SET}=${VALUE}" </dev/null >/dev/null || {
    echo "ERROR: Failed to update key=$KEY for agent=$AGENT in 1Password" >&2
    echo "       Item: $ITEM / Field: $OP_FIELD_SET" >&2
    exit 1
  }
else
  # Item doesn't exist — create it with the field
  op item create --vault "$VAULT" \
    --category "$OP_ITEM_CATEGORY" \
    --title "$ITEM" \
    "${OP_FIELD_SET}=${VALUE}" </dev/null >/dev/null || {
    echo "ERROR: Failed to create item for key=$KEY agent=$AGENT in 1Password" >&2
    echo "       Item: $ITEM / Category: $OP_ITEM_CATEGORY" >&2
    exit 1
  }
fi

echo "Stored: agent=$AGENT key=$KEY (1Password: $ITEM)"
