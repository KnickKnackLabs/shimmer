#!/usr/bin/env bash
#MISE description="List available agents"

# This just delegates to the agent home's agent:list task.
# We kept it because we couldn't be bothered to properly remove it.

set -e

if [ -z "${AGENT_HOME:-}" ]; then
  echo "Error: AGENT_HOME not set" >&2
  echo "Run: eval \$(shimmer as <agent>)" >&2
  exit 1
fi

mise -C "$AGENT_HOME" run -q agent:list
