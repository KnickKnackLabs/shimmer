#!/usr/bin/env bash
#MISE description="Start a local interactive Claude session as an agent"
#MISE quiet=true

set -e

# Derive agent name from environment (set by `shimmer as`)
if [ -z "$GIT_AUTHOR_NAME" ]; then
  echo "No agent identity detected. Run: eval \$(shimmer as <agent>)" >&2
  exit 1
fi
AGENT="$GIT_AUTHOR_NAME"

if [ -z "$AGENT_HOME" ]; then
  echo "AGENT_HOME not set. Run: eval \$(shimmer as <agent>)" >&2
  exit 1
fi

# Find agent identity file
if [ -n "$AGENT_IDENTITY" ] && [ -f "$AGENT_IDENTITY" ]; then
  AGENT_FILE="$AGENT_IDENTITY"
else
  echo "No agent identity file found." >&2
  if [ -z "$AGENT_IDENTITY" ]; then
    echo "AGENT_IDENTITY not set. Does your agent home provide an agent:identity task?" >&2
  else
    echo "AGENT_IDENTITY points to $AGENT_IDENTITY but the file does not exist." >&2
  fi
  echo "Run: eval \$(shimmer as <agent>)" >&2
  exit 1
fi

# Read prompt and pass to claude. Double-quoted variable expansion is safe
# against shell injection — special chars are not re-evaluated.
PROMPT=$(cat "$AGENT_FILE")

cd "${CALLER_PWD:-.}"
exec claude --append-system-prompt "$PROMPT

## Session Context
This is a local interactive session started via \`shimmer agent:local\`. A human is present and directing you."
