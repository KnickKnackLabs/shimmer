#!/usr/bin/env bash
#MISE description="Provision a new agent (credentials, GPG key, GitHub secrets)"
#USAGE arg "<agent-name>" help="Name of the agent to provision"
#USAGE flag "--force" help="Regenerate existing GPG key"
#USAGE flag "-p --secrets <provider>" help="Secret provider: 1password or keychain (overrides SECRETS_PROVIDER)"
#USAGE flag "--skip-org-sign" help="Skip org key signing (use when org key is unavailable)"
#USAGE flag "--skip-gh-secrets" help="Skip storing GPG keys as GitHub repo secrets"

set -e

AGENT="${usage_agent_name:?Usage: mise run agent:provision <agent-name> [--force]}"
FORCE="${usage_force:-}"
SKIP_ORG_SIGN="${usage_skip_org_sign:-}"
SKIP_GH_SECRETS="${usage_skip_gh_secrets:-}"
PROVIDER="${usage_secrets:-${SECRETS_PROVIDER:-${SHIMMER_SECRETS_PROVIDER:-}}}"
EMAIL="${AGENT}@ricon.family"
UPPER=$(echo "$AGENT" | tr '[:lower:]' '[:upper:]' | tr '-' '_')

# Target caller's repo for GitHub secrets (not shimmer's)
TARGET_DIR="${PROJECT_DIR:-${CALLER_PWD:-.}}"
cd "$TARGET_DIR"

# After cd, bare `mise run` resolves tasks from cwd (the caller's repo).
# Use `mise -C "$MISE_PROJECT_ROOT" run -q` to call sibling shimmer tasks.

echo "=== Provisioning agent: $AGENT ==="
echo ""

# Check prerequisites
if [ "$SKIP_ORG_SIGN" != "true" ] && ! gpg --list-keys admin@ricon.family >/dev/null 2>&1; then
  echo "ERROR: Org key (admin@ricon.family) not found in keyring."
  echo "       Use --skip-org-sign to skip org key signing"
  exit 1
fi

if [ -z "$PROVIDER" ]; then
  echo "ERROR: No secret provider specified." >&2
  echo "       Set SECRETS_PROVIDER=keychain|1password, or use --secrets <provider>" >&2
  exit 1
fi

export SECRETS_PROVIDER="$PROVIDER"

# === Account Credentials ===
# Generate passwords for services that onboard will set up interactively.
# Only generates if not already stored (idempotent).
echo "--- Account Credentials ---"

generate_password() {
  openssl rand -base64 18 | tr -d '/+=' | head -c 20
}

CREDENTIAL_KEYS=(email-password github-password matrix-password)

for key in "${CREDENTIAL_KEYS[@]}"; do
  if secrets get "$AGENT/$key" &>/dev/null; then
    echo "[auto] $key already stored"
  else
    value=$(generate_password)
    echo "[auto] Generating and storing $key..."
    printf '%s' "$value" | secrets set "$AGENT/$key"
  fi
done

# Store account metadata (deterministic values derived from agent name)
METADATA_KEYS=(
  "github-username:${AGENT}-ricon"
  "github-email:${EMAIL}"
  "github-country:United States of America"
  "matrix-username:@${AGENT}:ricon.family"
)

for entry in "${METADATA_KEYS[@]}"; do
  key="${entry%%:*}"
  value="${entry#*:}"
  if secrets get "$AGENT/$key" &>/dev/null; then
    echo "[auto] $key already stored"
  else
    echo "[auto] Storing $key..."
    printf '%s' "$value" | secrets set "$AGENT/$key"
  fi
done

echo ""

# === GPG Key ===
echo "--- GPG Key ---"
GPG_NEWLY_GENERATED=false

if gpg --list-keys "$EMAIL" >/dev/null 2>&1; then
  echo "[auto] Key for $EMAIL already in keyring"
  if [ "$FORCE" = "true" ]; then
    echo "[auto] --force: regenerating key..."
    EXISTING_FP=$(gpg --list-keys --keyid-format LONG "$EMAIL" | grep -A1 "^pub" | tail -1 | tr -d ' ')
    # Key existence was just verified above; a failure here is a real problem
    # (locked keyring, perms), but shouldn't block the regen attempt.
    if ! gpg --batch --yes --delete-secret-and-public-key "$EXISTING_FP" 2>/dev/null; then
      echo "[warn] failed to delete existing key $EXISTING_FP — re-import below may fail" >&2
    fi
  fi
fi

if ! gpg --list-keys "$EMAIL" >/dev/null 2>&1; then
  # Try to import from secret store first (idempotent re-provision).
  # Empty on missing key is expected (new agent); empty on provider failure
  # will cause the gen-key branch below to create a fresh key — which is
  # probably wrong if the provider is broken, but preferable to aborting mid-run.
  STORED_PRIVATE_KEY=$(secrets get "$AGENT/gpg-private-key" 2>/dev/null) || STORED_PRIVATE_KEY=""
  if [ -n "$STORED_PRIVATE_KEY" ]; then
    echo "[auto] Importing GPG key from secret store ($PROVIDER)..."
    # grep -v returns 1 when every line matches the filter (i.e. nothing to print).
    # Accept that specific exit; reject other failures (e.g. broken pipe).
    printf '%s' "$STORED_PRIVATE_KEY" | gpg --batch --import 2>&1 | grep -v "^gpg: Total" || [ $? -eq 1 ]
  else
    echo "[auto] Generating new GPG key for $EMAIL..."
    gpg --batch --gen-key << KEYSPEC
Key-Type: RSA
Key-Length: 4096
Name-Real: $AGENT
Name-Email: $EMAIL
Expire-Date: 0
%no-protection
%commit
KEYSPEC
    GPG_NEWLY_GENERATED=true
  fi
fi

# Sign with org key (idempotent — re-signing is a no-op)
FINGERPRINT=$(gpg --list-keys --keyid-format LONG "$EMAIL" | grep -A1 "^pub" | tail -1 | tr -d ' ')
if [ "$SKIP_ORG_SIGN" = "true" ]; then
  echo "[skip] Org key signing skipped (--skip-org-sign)"
  echo "       Export public key with: gpg --armor --export $EMAIL"
  echo "       Send to admin@ricon.family for signing"
else
  echo "[auto] Signing with org key..."
  if ! gpg --batch --yes --no-tty --local-user admin@ricon.family --quick-sign-key "$FINGERPRINT" 2>&1; then
    echo "[error] failed to sign agent key with admin@ricon.family — trust chain not established" >&2
    echo "[error] verify admin key is present: gpg --list-secret-keys admin@ricon.family" >&2
    exit 1
  fi
  # Verify the signature actually landed (catches cases where gpg reports
  # success but the sig didn't get attached).
  if ! gpg --list-sigs "$FINGERPRINT" | grep -q 'admin@ricon.family'; then
    echo "[error] signing reported success but no admin signature found on agent key" >&2
    exit 1
  fi
fi

KEY_ID=$(gpg --list-keys --keyid-format LONG "$EMAIL" | grep "^pub" | awk '{print $2}' | cut -d'/' -f2)
PRIVATE_KEY=$(gpg --armor --export-secret-keys "$EMAIL" 2>/dev/null)
PUBLIC_KEY=$(gpg --armor --export "$EMAIL" 2>/dev/null)

# === GitHub Secrets ===
echo ""
echo "--- GitHub Secrets ---"
if [ "$SKIP_GH_SECRETS" = "true" ]; then
  echo "[skip] GitHub secrets skipped (--skip-gh-secrets)"
else
  echo "[auto] Storing ${UPPER}_GPG_PRIVATE_KEY..."
  printf '%s' "$PRIVATE_KEY" | gh secret set "${UPPER}_GPG_PRIVATE_KEY"
  echo "[auto] Storing ${UPPER}_GPG_PUBLIC_KEY..."
  printf '%s' "$PUBLIC_KEY" | gh secret set "${UPPER}_GPG_PUBLIC_KEY"
fi

# === Secret Store ===
echo ""
echo "--- Secret Store ($PROVIDER) ---"

store() {
  local key="$1"; local value="$2"
  if ! printf '%s' "$value" | secrets set "$AGENT/$key"; then
    echo "  WARN: Failed to store $key — check provider ($PROVIDER) configuration" >&2
    STORE_FAILURES=$((STORE_FAILURES + 1))
  fi
}
STORE_FAILURES=0

if [ "$GPG_NEWLY_GENERATED" = "true" ] || \
   ! secrets get "$AGENT/gpg-private-key" &>/dev/null; then
  echo "[auto] Storing GPG keys..."
  store gpg-private-key "$PRIVATE_KEY"
  store gpg-public-key "$PUBLIC_KEY"
  store gpg-key-id "$KEY_ID"
  store gpg-fingerprint "$FINGERPRINT"
else
  echo "[auto] GPG keys already stored"
fi


echo ""
if [ "$STORE_FAILURES" -gt 0 ]; then
  echo "=== $AGENT provisioned (with $STORE_FAILURES secret store warning(s)) ==="
  echo ""
  echo "Some secrets failed to store. Check provider ($PROVIDER) configuration and retry."
else
  echo "=== $AGENT provisioned ==="
fi
echo ""
echo "Next: mise run agent:onboard $AGENT"
