#!/usr/bin/env bash
#MISE description="Provision a new agent (GPG key, GitHub secrets, secret store)"
#USAGE arg "<agent-name>" help="Name of the agent to provision"
#USAGE flag "--force" help="Regenerate existing GPG key"
#USAGE flag "-p --secrets <provider>" help="Secret provider: 1password or keychain (overrides SHIMMER_SECRETS_PROVIDER)"
#USAGE flag "--skip-org-sign" help="Skip org key signing (use when org key is unavailable)"
#USAGE flag "--skip-gh-secrets" help="Skip storing GPG keys as GitHub repo secrets"

set -e

AGENT="${usage_agent_name:?Usage: mise run agent:provision <agent-name> [--force]}"
FORCE="${usage_force:-}"
SKIP_ORG_SIGN="${usage_skip_org_sign:-}"
SKIP_GH_SECRETS="${usage_skip_gh_secrets:-}"
PROVIDER="${usage_secrets:-${SHIMMER_SECRETS_PROVIDER:-}}"
EMAIL="${AGENT}@ricon.family"
UPPER=$(echo "$AGENT" | tr '[:lower:]' '[:upper:]' | tr '-' '_')

# Target caller's repo for GitHub secrets (not shimmer's)
TARGET_DIR="${PROJECT_DIR:-${CALLER_PWD:-.}}"
cd "$TARGET_DIR"

echo "=== Provisioning agent: $AGENT ==="
echo ""

# Check prerequisites
if [ "$SKIP_ORG_SIGN" != "true" ] && ! gpg --list-keys admin@ricon.family >/dev/null 2>&1; then
  echo "ERROR: Org key (admin@ricon.family) not found in keyring."
  echo "       Use --skip-org-sign to skip org key signing"
  exit 1
fi

if [ -z "$PROVIDER" ]; then
  echo "ERROR: No secret provider specified." >&2
  echo "       Set SHIMMER_SECRETS_PROVIDER=keychain|1password, or use --secrets <provider>" >&2
  exit 1
fi

# === GPG Key ===
echo "--- GPG Key ---"
GPG_NEWLY_GENERATED=false

if gpg --list-keys "$EMAIL" >/dev/null 2>&1; then
  echo "[auto] Key for $EMAIL already in keyring"
  if [ "$FORCE" = "true" ]; then
    echo "[auto] --force: regenerating key..."
    EXISTING_FP=$(gpg --list-keys --keyid-format LONG "$EMAIL" | grep -A1 "^pub" | tail -1 | tr -d ' ')
    gpg --batch --yes --delete-secret-and-public-key "$EXISTING_FP" 2>/dev/null || true
  fi
fi

if ! gpg --list-keys "$EMAIL" >/dev/null 2>&1; then
  # Try to import from secret store first (idempotent re-provision)
  STORED_PRIVATE_KEY=$(mise run -q secret:get "$AGENT" gpg-private-key 2>/dev/null || true)
  if [ -n "$STORED_PRIVATE_KEY" ]; then
    echo "[auto] Importing GPG key from secret store ($PROVIDER)..."
    printf '%s' "$STORED_PRIVATE_KEY" | gpg --batch --import 2>&1 | grep -v "^gpg: Total" || true
  else
    echo "[auto] Generating new GPG key for $EMAIL..."
    gpg --batch --gen-key << KEYSPEC
Key-Type: RSA
Key-Length: 4096
Name-Real: $AGENT
Name-Email: $EMAIL
Expire-Date: 0
%no-protection
%commit
KEYSPEC
    GPG_NEWLY_GENERATED=true
  fi
fi

# Sign with org key (idempotent — re-signing is a no-op)
FINGERPRINT=$(gpg --list-keys --keyid-format LONG "$EMAIL" | grep -A1 "^pub" | tail -1 | tr -d ' ')
if [ "$SKIP_ORG_SIGN" = "true" ]; then
  echo "[skip] Org key signing skipped (--skip-org-sign)"
  echo "       Export public key with: gpg --armor --export $EMAIL"
  echo "       Send to admin@ricon.family for signing"
else
  echo "[auto] Signing with org key..."
  gpg --batch --yes --no-tty --local-user admin@ricon.family --quick-sign-key "$FINGERPRINT" 2>&1 || true
fi

KEY_ID=$(gpg --list-keys --keyid-format LONG "$EMAIL" | grep "^pub" | awk '{print $2}' | cut -d'/' -f2)
PRIVATE_KEY=$(gpg --armor --export-secret-keys "$EMAIL" 2>/dev/null)
PUBLIC_KEY=$(gpg --armor --export "$EMAIL" 2>/dev/null)

# === GitHub Secrets ===
echo ""
echo "--- GitHub Secrets ---"
if [ "$SKIP_GH_SECRETS" = "true" ]; then
  echo "[skip] GitHub secrets skipped (--skip-gh-secrets)"
else
  echo "[auto] Storing ${UPPER}_GPG_PRIVATE_KEY..."
  printf '%s' "$PRIVATE_KEY" | gh secret set "${UPPER}_GPG_PRIVATE_KEY"
  echo "[auto] Storing ${UPPER}_GPG_PUBLIC_KEY..."
  printf '%s' "$PUBLIC_KEY" | gh secret set "${UPPER}_GPG_PUBLIC_KEY"
fi

# === Secret Store ===
echo ""
echo "--- Secret Store ($PROVIDER) ---"

export SHIMMER_SECRETS_PROVIDER="$PROVIDER"
store() {
  local key="$1"; local value="$2"
  printf '%s' "$value" | mise run -q secret:set "$AGENT" "$key" || true
}

if [ "$GPG_NEWLY_GENERATED" = "true" ] || \
   ! mise run -q secret:get "$AGENT" gpg-private-key &>/dev/null; then
  echo "[auto] Storing GPG keys..."
  store gpg-private-key "$PRIVATE_KEY"
  store gpg-public-key "$PUBLIC_KEY"
  store gpg-key-id "$KEY_ID"
  store gpg-fingerprint "$FINGERPRINT"
else
  echo "[auto] GPG keys already stored"
fi

echo ""
echo "=== $AGENT provisioned ==="
echo ""
echo "Next: mise run agent:onboard $AGENT"
