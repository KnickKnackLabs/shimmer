#!/usr/bin/env bash
#MISE description="Sync agent secrets from secret provider to GitHub"
#USAGE arg "[agent]" help="Agent to sync (omit for all agents)"
#USAGE flag "--dry-run" help="Show what would be synced without making changes"
#USAGE flag "--with-api-key" help="Also sync the shared ANTHROPIC_API_KEY secret"
#USAGE flag "-p --provider <provider>" help="Secret provider: keychain or 1password (overrides SECRETS_PROVIDER)"

set -e

source "$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)/lib/gpg.sh"

# Determine target directory (caller's directory when using shimmer alias)
TARGET_DIR="${PROJECT_DIR:-${CALLER_PWD:-.}}"
cd "$TARGET_DIR"

AGENT="${usage_agent:-}"
DRY_RUN="${usage_dry_run:-false}"
WITH_API_KEY="${usage_with_api_key:-false}"
PROVIDER="${usage_provider:-${SECRETS_PROVIDER:-${SHIMMER_SECRETS_PROVIDER:-}}}"

if [ -z "$PROVIDER" ]; then
  echo "ERROR: No secret provider specified." >&2
  echo "       Set SECRETS_PROVIDER=keychain|1password, or use --provider <provider>" >&2
  exit 1
fi

export SECRETS_PROVIDER="$PROVIDER"

# Delegate agent discovery to the home's agent:list task
get_agents() {
  local home_dir
  home_dir=$(git -C "$TARGET_DIR" rev-parse --show-toplevel 2>/dev/null || echo "$TARGET_DIR")
  mise -C "$home_dir" run -q agent:list 2>/dev/null || {
    echo "ERROR: Could not list agents." >&2
    echo "Does the home provide an 'agent:list' task?" >&2
    echo "Or specify a single agent: shimmer agent:sync-secrets <agent>" >&2
    return 1
  }
}

# Map from secret key to GitHub secret name suffix
gh_secret_name() {
  local agent_upper="$1"
  local key="$2"
  case "$key" in
    email-password)   echo "${agent_upper}_EMAIL_PASSWORD" ;;
    github-pat)       echo "${agent_upper}_GITHUB_PAT" ;;
    github-password)  echo "${agent_upper}_GITHUB_PASSWORD" ;;
    matrix-password)  echo "${agent_upper}_MATRIX_PASSWORD" ;;
    gpg-private-key)  echo "${agent_upper}_GPG_PRIVATE_KEY" ;;
    gpg-public-key)   echo "${agent_upper}_GPG_PUBLIC_KEY" ;;
    b2-endpoint)      echo "${agent_upper}_B2_ENDPOINT" ;;
    b2-key-id)        echo "${agent_upper}_B2_KEY_ID" ;;
    b2-application-key) echo "${agent_upper}_B2_APPLICATION_KEY" ;;
    b2-bucket)        echo "${agent_upper}_B2_BUCKET" ;;
    *)                return 1 ;;
  esac
}

# Keys to sync to GitHub (not all secret keys need syncing)
SYNC_KEYS=(
  email-password
  github-pat
  github-password
  matrix-password
  gpg-private-key
  gpg-public-key
  b2-endpoint
  b2-key-id
  b2-application-key
  b2-bucket
)

sync_agent() {
  local agent="$1"
  local agent_upper
  agent_upper=$(echo "$agent" | tr '[:lower:]' '[:upper:]' | tr '-' '_')

  echo "=== Syncing $agent ==="

  for key in "${SYNC_KEYS[@]}"; do
    local gh_name
    gh_name=$(gh_secret_name "$agent_upper" "$key") || continue

    local value
    value=$(secrets get "$agent/$key" 2>/dev/null) || true # codebase:ignore or-true  not all agents have all keys; missing values handled by skip message below

    if [ -n "$value" ]; then
      # Strip wrapping quotes (some providers quote multiline values)
      if [ "$key" = "gpg-private-key" ] || [ "$key" = "gpg-public-key" ]; then
        value=$(strip_wrapping_quotes "$value")
      fi

      # Validate GPG keys before upload
      if [ "$key" = "gpg-private-key" ] || [ "$key" = "gpg-public-key" ]; then
        if ! validate_gpg_key "$value"; then
          echo "  [ERROR] $gh_name failed validation, skipping" >&2
          continue
        fi
      fi

      if [ "$DRY_RUN" = "true" ]; then
        echo "  [dry-run] Would sync $gh_name"
      else
        echo "  Syncing $gh_name..."
        # Use --body for multiline values (GPG keys), pipe for single-line
        if [ "$key" = "gpg-private-key" ] || [ "$key" = "gpg-public-key" ]; then
          gh secret set "$gh_name" --body "$value"
        else
          echo "$value" | gh secret set "$gh_name"
        fi
      fi
    else
      echo "  [skip] No $key found"
    fi
  done

  echo ""
}

echo "Syncing secrets ($PROVIDER) → GitHub"
echo ""

if [ -n "$AGENT" ]; then
  # Single agent — trust the caller, no need to validate against agents/
  sync_agent "$AGENT"
else
  # All agents
  for agent in $(get_agents); do
    sync_agent "$agent"
  done
fi

# Sync shared Anthropic API key (only if --with-api-key flag is set)
if [ "$WITH_API_KEY" = "true" ]; then
  echo "=== Syncing shared ANTHROPIC_API_KEY ==="
  TOKEN=$(secrets get "shared/anthropic-api-key" 2>/dev/null) || true # codebase:ignore or-true  key may not exist; empty value handled by explicit error message below
  if [ -z "$TOKEN" ]; then
    echo "  [error] No shared/anthropic-api-key found in secret provider"
  elif [ "$DRY_RUN" = "true" ]; then
    echo "  [dry-run] Would sync ANTHROPIC_API_KEY"
  else
    echo "  Syncing ANTHROPIC_API_KEY..."
    echo "$TOKEN" | gh secret set ANTHROPIC_API_KEY
    echo "  Done"
  fi
  echo ""
fi

if [ "$DRY_RUN" = "true" ]; then
  echo "Dry run complete. No secrets were changed."
else
  echo "Sync complete!"
fi
