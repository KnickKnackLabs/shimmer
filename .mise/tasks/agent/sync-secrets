#!/usr/bin/env bash
#MISE description="Sync agent secrets from 1Password to GitHub"
#USAGE arg "[agent]" help="Agent to sync (omit for all agents)"
#USAGE flag "--dry-run" help="Show what would be synced without making changes"
#USAGE flag "--with-oauth" help="Also refresh the shared Claude OAuth token (interactive)"

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../_secret-keys"

# Determine target directory (caller's directory when using shimmer alias)
TARGET_DIR="${PROJECT_DIR:-${CALLER_PWD:-.}}"
cd "$TARGET_DIR"

AGENT="${usage_agent:-}"
DRY_RUN="${usage_dry_run:-false}"
WITH_OAUTH="${usage_with_oauth:-false}"

# Discover agents from the agents/ directory
get_agents() {
  if [ -d "agents" ]; then
    ls -d agents/*/ 2>/dev/null \
      | xargs -n1 basename \
      | sort
  else
    echo "ERROR: No agents/ directory found. Cannot discover agents." >&2
    echo "Either run from a repo with an agents/ directory or specify a single agent:" >&2
    echo "  shimmer agent:sync-secrets <agent>" >&2
    return 1
  fi
}

# Map from secret key to GitHub secret name suffix
gh_secret_name() {
  local agent_upper="$1"
  local key="$2"
  case "$key" in
    email-password)   echo "${agent_upper}_EMAIL_PASSWORD" ;;
    github-pat)       echo "${agent_upper}_GITHUB_PAT" ;;
    github-password)  echo "${agent_upper}_GITHUB_PASSWORD" ;;
    matrix-password)  echo "${agent_upper}_MATRIX_PASSWORD" ;;
    passphrase)       echo "${agent_upper}_PASSPHRASE" ;;
    gpg-private-key)  echo "${agent_upper}_GPG_PRIVATE_KEY" ;;
    gpg-public-key)   echo "${agent_upper}_GPG_PUBLIC_KEY" ;;
    *)                return 1 ;;
  esac
}

# Keys to sync to GitHub (not all secret keys need syncing)
SYNC_KEYS=(
  email-password
  github-pat
  github-password
  matrix-password
  passphrase
  gpg-private-key
  gpg-public-key
)

sync_agent() {
  local agent="$1"
  local agent_upper
  agent_upper=$(echo "$agent" | tr '[:lower:]' '[:upper:]' | tr '-' '_')

  echo "=== Syncing $agent ==="

  for key in "${SYNC_KEYS[@]}"; do
    local gh_name
    gh_name=$(gh_secret_name "$agent_upper" "$key") || continue

    # Use 1password:get via mise (respects shared key registry)
    local value
    value=$(SHIMMER_SECRETS_PROVIDER=1password mise run -q secret:get "$agent" "$key" 2>/dev/null) || true

    if [ -n "$value" ]; then
      if [ "$DRY_RUN" = "true" ]; then
        echo "  [dry-run] Would sync $gh_name"
      else
        echo "  Syncing $gh_name..."
        # Use --body for multiline values (GPG keys), pipe for single-line
        if [ "$key" = "gpg-private-key" ] || [ "$key" = "gpg-public-key" ]; then
          gh secret set "$gh_name" --body "$value"
        else
          echo "$value" | gh secret set "$gh_name"
        fi
      fi
    else
      echo "  [skip] No $key found in 1Password"
    fi
  done

  echo ""
}

# Check prerequisites
if ! command -v op &> /dev/null; then
  echo "ERROR: 1Password CLI (op) not found."
  exit 1
fi

if ! op account get &> /dev/null; then
  echo "ERROR: Not signed in to 1Password. Run: op signin"
  exit 1
fi

echo "Syncing secrets from 1Password → GitHub"
echo ""

if [ -n "$AGENT" ]; then
  # Single agent — trust the caller, no need to validate against agents/
  sync_agent "$AGENT"
else
  # All agents
  for agent in $(get_agents); do
    sync_agent "$agent"
  done
fi

# Sync shared Claude OAuth token (only if --with-oauth flag is set)
if [ "$WITH_OAUTH" = "true" ]; then
  echo "=== Syncing shared OAuth token ==="
  if [ "$DRY_RUN" = "true" ]; then
    echo "  [dry-run] Would refresh CLAUDE_CODE_OAUTH_TOKEN"
  else
    echo "  Refreshing CLAUDE_CODE_OAUTH_TOKEN (interactive)..."
    RAW_OUTPUT=$(claude setup-token 2>&1)
    TOKEN=$(echo "$RAW_OUTPUT" | grep -o 'sk-ant-[A-Za-z0-9_-]*')
    if [ -z "$TOKEN" ]; then
      echo "  [error] Failed to get OAuth token from Claude"
    else
      gh secret set CLAUDE_CODE_OAUTH_TOKEN --body "$TOKEN"
      echo "  Done"
    fi
  fi
  echo ""
fi

if [ "$DRY_RUN" = "true" ]; then
  echo "Dry run complete. No secrets were changed."
else
  echo "Sync complete!"
fi
