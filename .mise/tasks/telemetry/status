#!/usr/bin/env bash
#MISE description="Show telemetry configuration and stats"
set -euo pipefail

echo "Telemetry Status"
echo ""

if [ -z "${TELEMETRY_FILE:-}" ]; then
  echo "  TELEMETRY_FILE  (not set — telemetry is off)"
  echo ""
  echo "  To enable: export TELEMETRY_FILE=~/path/to/telemetry.jsonl"
  exit 0
fi

echo "  TELEMETRY_FILE  $TELEMETRY_FILE"

if [ -n "${TELEMETRY_HOOK:-}" ]; then
  if [ -x "$TELEMETRY_HOOK" ]; then
    echo "  TELEMETRY_HOOK  $TELEMETRY_HOOK"
  else
    echo "  TELEMETRY_HOOK  $TELEMETRY_HOOK (⚠ not executable)"
  fi
else
  echo "  TELEMETRY_HOOK  (not set)"
fi

echo ""

if [ ! -f "$TELEMETRY_FILE" ]; then
  echo "  No events yet (file does not exist)"
  exit 0
fi

EVENT_COUNT=$(wc -l < "$TELEMETRY_FILE" | tr -d ' ')
FILE_SIZE=$(du -h "$TELEMETRY_FILE" | cut -f1)

# Date range
FIRST_TS=$(head -1 "$TELEMETRY_FILE" | jq -r '.ts // empty' 2>/dev/null || echo "")
LAST_TS=$(tail -1 "$TELEMETRY_FILE" | jq -r '.ts // empty' 2>/dev/null || echo "")

echo "  Events        $EVENT_COUNT"
echo "  File size     $FILE_SIZE"
if [ -n "$FIRST_TS" ] && [ -n "$LAST_TS" ]; then
  echo "  First event   $FIRST_TS"
  echo "  Last event    $LAST_TS"
fi

echo ""

# Tools breakdown
echo "  By tool:"
HEADER=$'tool\tcount'
TABLE=$(jq -r '.tool' "$TELEMETRY_FILE" 2>/dev/null | sort | uniq -c | sort -rn | awk '{tool=$2; count=$1; printf "%s\t%s\n", tool, count}')
if [ -n "$TABLE" ]; then
  printf '%s\n%s\n' "$HEADER" "$TABLE" | gum table --print --separator $'\t' --border rounded \
    --border.foreground 240 --header.foreground 81
fi
