#!/usr/bin/env bash
#MISE description="Store a secret in macOS Keychain"
#USAGE arg "<agent>" help="Agent name (e.g., zeke, baby-joel)"
#USAGE arg "<key>" help="Secret key (e.g., github-pat, gpg-private-key, email-password)"
#USAGE flag "-v --value <value>" help="Value to store (or pipe via stdin)"

set -eo pipefail

AGENT="${usage_agent:-${1:?Usage: keychain:set <agent> <key>}}"
KEY="${usage_key:-${2:?Usage: keychain:set <agent> <key>}}"
VALUE="${usage_value:-}"
SERVICE="shimmer-${KEY}"

if ! command -v security &>/dev/null; then
  echo "ERROR: macOS 'security' command not found (not on macOS?)" >&2
  exit 1
fi

# Read from stdin if no --value provided
if [ -z "$VALUE" ]; then
  if [ -t 0 ]; then
    echo "ERROR: No value provided. Use --value or pipe via stdin." >&2
    exit 1
  fi
  VALUE=$(cat)
fi

if [ -z "$VALUE" ]; then
  echo "ERROR: Empty value." >&2
  exit 1
fi

# Base64-encode to avoid macOS Keychain hex-encoding multi-line values
ENCODED=$(printf '%s' "$VALUE" | base64)

# -U updates if exists, creates if not
security add-generic-password -a "$AGENT" -s "$SERVICE" -w "$ENCODED" -U 2>/dev/null

echo "Stored: agent=$AGENT key=$KEY (service=$SERVICE)"
