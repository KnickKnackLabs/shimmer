#!/usr/bin/env bash
#MISE description="Search the web (default provider: brave)"
#USAGE arg "<query>" help="Search query"
#USAGE flag "-n --count <count>" help="Number of results (default: 5)"
#USAGE flag "--json" help="Output raw JSON"

set -euo pipefail

# Build args for the provider task
args=("${usage_query}")
[[ -n "${usage_count:-}" ]] && args+=(-n "${usage_count}")
[[ "${usage_json:-false}" == "true" ]] && args+=(--json)

exec mise run -q web:search:brave "${args[@]}"
