#!/usr/bin/env bash
#MISE description="Download a blob from storage"
#USAGE arg "<key>" help="Object key to download"
#USAGE arg "[dest]" help="Local destination path (default: stdout)"

set -euo pipefail

source "$MISE_CONFIG_ROOT/.mise/tasks/_blob-env"

KEY="$usage_key"
DEST="${usage_dest:-}"

if [ -z "$DEST" ]; then
  # Output to stdout
  mc cat "${BLOB_TARGET}/${KEY}"
else
  mc cp -q "${BLOB_TARGET}/${KEY}" "$DEST"
  echo "Downloaded: ${KEY} -> ${DEST}" >&2
fi
