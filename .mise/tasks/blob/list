#!/usr/bin/env bash
#MISE description="List blobs in storage"
#USAGE arg "[prefix]" help="Key prefix to filter (e.g., sessions/)"
#USAGE flag "--json" help="Output as JSON"

set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../_blob-env"

PREFIX="${usage_prefix:-}"
JSON="${usage_json:-false}"

TARGET="${BLOB_TARGET}"
[ -n "$PREFIX" ] && TARGET="${TARGET}/${PREFIX}"

if [ "$JSON" = "true" ]; then
  mc ls --json "$TARGET"
else
  mc ls "$TARGET"
fi
