#!/bin/bash
#MISE description="Resolve the HUMAN.md path via the home repo's human task"
#MISE hide=true
# Usage: HUMAN_PATH=$(.mise/tasks/_get-human-path)
#
# Calls the home repo's `human` task to get the HUMAN.md path.
# Requires CALLER_PWD to be set (or uses current directory).
# Fails with exit 1 if the home repo doesn't provide a `human` task.

set -eo pipefail

CALLER_DIR="${CALLER_PWD:-$(pwd)}"

HUMAN_PATH=$(mise -C "$CALLER_DIR" run -q human 2>/dev/null) || true

if [ -z "$HUMAN_PATH" ]; then
  echo "Error: could not resolve HUMAN.md path." >&2
  echo "Does $CALLER_DIR provide a 'human' task?" >&2
  exit 1
fi

echo "$HUMAN_PATH"
