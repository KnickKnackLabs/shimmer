#!/usr/bin/env bash
#MISE description="Launch a browser instance for this agent"
#USAGE flag "--headed" help="Launch in headed mode (visible browser window)"
#USAGE flag "--user-data-dir <dir>" help="Custom user data directory"

set -e

# Determine agent identity
if [ -n "$GIT_AUTHOR_EMAIL" ]; then
  AGENT=$(echo "$GIT_AUTHOR_EMAIL" | sed 's/@ricon\.family$//')
elif git config user.email 2>/dev/null | grep -q '@ricon.family'; then
  AGENT=$(git config user.email | sed 's/@ricon\.family$//')
else
  echo "No agent identity detected. Run: eval \$(shimmer as <agent>)" >&2
  exit 1
fi

# Browser cache
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/shimmer/browser"
export PLAYWRIGHT_BROWSERS_PATH="$CACHE_DIR"

if [ ! -d "$CACHE_DIR" ] || ! ls "$CACHE_DIR"/chromium-* &>/dev/null; then
  echo "Chromium not installed. Run: shimmer browser:setup" >&2
  exit 1
fi

# Generate browser ID (retry on collision)
ID="b-$(openssl rand -hex 2)"
while [ -f "/tmp/shimmer-browser-id-${ID}.json" ] && kill -0 "$(jq -r '.pid' "/tmp/shimmer-browser-id-${ID}.json" 2>/dev/null)" 2>/dev/null; do
  ID="b-$(openssl rand -hex 2)"
done

# Find a free port starting from agent's base port
BASE_PORT=$(echo -n "$AGENT" | cksum | awk '{print 9200 + ($1 % 200)}')
PORT=$BASE_PORT
while lsof -i ":$PORT" >/dev/null 2>&1; do
  PORT=$((PORT + 1))
  if [ $PORT -ge 9400 ]; then
    echo "No free ports in range 9200-9399" >&2
    exit 1
  fi
done

# Find Chromium binary via Patchright (run from scripts/ where node_modules lives)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CHROMIUM_PATH=$(cd "$SCRIPT_DIR/scripts" && node -e "
  import { chromium } from 'patchright';
  console.log(chromium.executablePath());
" 2>/dev/null) || true

if [ -z "$CHROMIUM_PATH" ] || [ ! -f "$CHROMIUM_PATH" ]; then
  echo "Could not find Chromium binary. Run: shimmer browser:setup" >&2
  exit 1
fi

# Launch Chromium with remote debugging
HEADLESS_FLAG="--headless=new"
if [ "${usage_headed:-false}" = "true" ]; then
  HEADLESS_FLAG=""
fi

USER_DATA_ARGS=()
if [[ -n "${usage_user_data_dir:-}" ]]; then
  USER_DATA_ARGS+=("--user-data-dir=$usage_user_data_dir")
fi

"$CHROMIUM_PATH" \
  --remote-debugging-port="$PORT" \
  --no-first-run \
  --no-default-browser-check \
  --allow-chrome-scheme-url \
  ${HEADLESS_FLAG:+"$HEADLESS_FLAG"} \
  "${USER_DATA_ARGS[@]}" \
  &>/dev/null &

BROWSER_PID=$!

# Wait briefly for startup
sleep 1

if ! kill -0 "$BROWSER_PID" 2>/dev/null; then
  echo "Failed to launch Chromium" >&2
  exit 1
fi

# Write PID files
USER_DATA_DIR_JSON=""
if [[ -n "${usage_user_data_dir:-}" ]]; then
  USER_DATA_DIR_JSON=", \"user_data_dir\": \"$usage_user_data_dir\""
fi
PID_DATA="{\"pid\": $BROWSER_PID, \"port\": $PORT, \"agent\": \"$AGENT\", \"id\": \"$ID\"${USER_DATA_DIR_JSON}}"

# ID-based PID file (canonical)
echo "$PID_DATA" > "/tmp/shimmer-browser-id-${ID}.json"

# Agent-default PID file (backward compat — points to latest browser)
echo "$PID_DATA" > "/tmp/shimmer-browser-${AGENT}.json"

# Output ID to stdout (for capture), human info to stderr
echo "$ID"
echo "Browser launched for $AGENT" >&2
echo "  ID:   $ID" >&2
echo "  PID:  $BROWSER_PID" >&2
echo "  Port: $PORT" >&2
