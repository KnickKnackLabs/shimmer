#!/usr/bin/env bash
#MISE description="Navigate browser to a URL"
#USAGE arg "<url>" help="URL to navigate to"
#USAGE flag "-b --browser <browser>" help="Browser ID (default: agent's latest browser)"

set -e

URL="${usage_url:?Usage: shimmer browser:goto <url>}"
BROWSER_ID="${usage_browser:-}"

# Determine agent identity
if [ -n "$GIT_AUTHOR_EMAIL" ]; then
  AGENT=$(echo "$GIT_AUTHOR_EMAIL" | sed 's/@ricon\.family$//')
elif git config user.email 2>/dev/null | grep -q '@ricon.family'; then
  AGENT=$(git config user.email | sed 's/@ricon\.family$//')
else
  echo "No agent identity detected. Run: eval \$(shimmer as <agent>)" >&2
  exit 1
fi

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/shimmer/browser"
export PLAYWRIGHT_BROWSERS_PATH="$CACHE_DIR"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

ARGS=(--action goto --agent "$AGENT")
if [ -n "$BROWSER_ID" ]; then
  ARGS+=(--browser "$BROWSER_ID")
fi

node "$SCRIPT_DIR/scripts/_cdp.mjs" "${ARGS[@]}" "$URL"
