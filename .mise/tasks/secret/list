#!/usr/bin/env bash
#MISE description="List known secret keys for an agent"
#USAGE arg "[agent]" help="Agent name (optional — shows all keys if omitted)"
#USAGE flag "-p --provider <provider>" help="Secret provider: keychain or 1password (overrides SHIMMER_SECRETS_PROVIDER)"

set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../_secret-keys"

AGENT="${usage_agent:-}"
PROVIDER="${usage_provider:-${SHIMMER_SECRETS_PROVIDER:-}}"

if [ -z "$PROVIDER" ]; then
  # No provider — just print known keys (no lookups)
  echo "Known secret keys:"
  for key in "${KNOWN_SECRET_KEYS[@]}"; do
    echo "  $key"
  done
  echo ""
  echo "Set SHIMMER_SECRETS_PROVIDER=keychain|1password (or --provider) to check which are stored."
  exit 0
fi

VAULT="Agents"

case "$PROVIDER" in
  keychain)
    if ! command -v security &>/dev/null; then
      echo "ERROR: macOS 'security' command not found." >&2; exit 1
    fi
    echo "Keychain secrets${AGENT:+ for $AGENT}:"
    for key in "${KNOWN_SECRET_KEYS[@]}"; do
      SERVICE="shimmer-${key}"
      if [ -n "$AGENT" ]; then
        if security find-generic-password -a "$AGENT" -s "$SERVICE" -w &>/dev/null; then
          echo "  ✓ $key"
        else
          echo "  ✗ $key"
        fi
      else
        # Show all agents that have this key
        ACCOUNTS=$(security dump-keychain 2>/dev/null | grep -A3 "\"$SERVICE\"" | grep "acct" | sed 's/.*<blob>="//' | sed 's/".*//' || true)
        if [ -n "$ACCOUNTS" ]; then
          echo "  $key: $(echo "$ACCOUNTS" | tr '\n' ' ')"
        fi
      fi
    done
    ;;
  1password)
    if ! command -v op &>/dev/null; then
      echo "ERROR: 1Password CLI (op) not found." >&2; exit 1
    fi
    if ! op account get &>/dev/null; then
      echo "ERROR: Not signed in to 1Password. Run: op signin" >&2; exit 1
    fi
    echo "1Password secrets${AGENT:+ for $AGENT}:"
    if [ -z "$AGENT" ]; then
      echo "  (specify an agent name to check stored keys)"
      exit 0
    fi
    for key in "${KNOWN_SECRET_KEYS[@]}"; do
      if resolve_key "$key"; then
        ITEM="${AGENT} - ${OP_ITEM_SUFFIX}"
        if op item get "$ITEM" --vault "$VAULT" --fields "$OP_FIELD_GET" --reveal &>/dev/null; then
          echo "  ✓ $key"
        else
          echo "  ✗ $key"
        fi
      fi
    done
    ;;
  *)
    echo "ERROR: Unknown provider: $PROVIDER" >&2
    echo "       Valid providers: keychain, 1password" >&2
    exit 1
    ;;
esac
