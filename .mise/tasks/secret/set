#!/usr/bin/env bash
#MISE description="Store a secret for an agent (provider-transparent)"
#USAGE arg "<agent>" help="Agent name (e.g., zeke, baby-joel)"
#USAGE arg "<key>" help="Secret key (e.g., github-pat, gpg-private-key)"
#USAGE flag "-v --value <value>" help="Value to store (or pipe via stdin)"
#USAGE flag "-p --provider <provider>" help="Secret provider: keychain or 1password (overrides SHIMMER_SECRETS_PROVIDER)"

set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

AGENT="${usage_agent:?}"
KEY="${usage_key:?}"
PROVIDER="${usage_provider:-${SHIMMER_SECRETS_PROVIDER:-}}"
VALUE_FLAG="${usage_value:+--value}"
VALUE="${usage_value:-}"

if [ -z "$PROVIDER" ]; then
  echo "ERROR: No secret provider specified." >&2
  echo "       Set SHIMMER_SECRETS_PROVIDER=keychain|1password, or use --provider <provider>" >&2
  exit 1
fi

# Build args for backend — pass --value if provided, otherwise backend reads stdin
ARGS=("$AGENT" "$KEY")
[ -n "$VALUE" ] && ARGS+=(--value "$VALUE")

case "$PROVIDER" in
  keychain)
    exec "$SCRIPT_DIR/../keychain/set" "${ARGS[@]}"
    ;;
  1password)
    exec "$SCRIPT_DIR/../1password/set" "${ARGS[@]}"
    ;;
  *)
    echo "ERROR: Unknown provider: $PROVIDER" >&2
    echo "       Valid providers: keychain, 1password" >&2
    exit 1
    ;;
esac
