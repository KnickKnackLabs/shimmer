#!/usr/bin/env bash
#MISE description="Trigger a workflow run and return the run ID"
#USAGE arg "<workflow>" help="Workflow filename (e.g., zeke.yml, deploy.yml)"
#USAGE arg "[inputs...]" help="Workflow inputs as key=value pairs"
#USAGE flag "--repo <repo>" help="Repository (owner/name), defaults to current directory's repo"
#USAGE flag "--timeout <seconds>" help="Max time to wait for run to appear (default: 120)"

set -e

SCRIPT_DIR="$(dirname "$0")"

# Parse a shell-escaped word list emitted by mise's #USAGE variadic args.
# Example shape: `'message=hello world' 'model=opus'`
# We can't use xargs here because it breaks on embedded newlines.
parse_shell_words() {
  local input="$1"
  PARSED_WORDS=()

  local word=""
  local state="unquoted"
  local word_started=false
  local i ch

  for ((i = 0; i < ${#input}; i++)); do
    ch="${input:i:1}"

    case "$state" in
      unquoted)
        case "$ch" in
          [[:space:]])
            if $word_started; then
              PARSED_WORDS+=("$word")
              word=""
              word_started=false
            fi
            ;;
          "'")
            state="single"
            word_started=true
            ;;
          '"')
            state="double"
            word_started=true
            ;;
          \\)
            state="escape"
            word_started=true
            ;;
          *)
            word+="$ch"
            word_started=true
            ;;
        esac
        ;;
      single)
        if [[ "$ch" == "'" ]]; then
          state="unquoted"
        else
          word+="$ch"
        fi
        ;;
      double)
        case "$ch" in
          '"')
            state="unquoted"
            ;;
          \\)
            state="double_escape"
            ;;
          *)
            word+="$ch"
            ;;
        esac
        ;;
      escape)
        word+="$ch"
        state="unquoted"
        ;;
      double_escape)
        case "$ch" in
          '"'|\\|'$'|'`')
            word+="$ch"
            ;;
          *)
            word+="\\$ch"
            ;;
        esac
        state="double"
        ;;
    esac
  done

  case "$state" in
    unquoted)
      if $word_started; then
        PARSED_WORDS+=("$word")
      fi
      ;;
    *)
      echo "Error: malformed shell-escaped input list" >&2
      return 1
      ;;
  esac
}

# Determine repo
if [[ -n "${usage_repo:-}" ]]; then
  REPO="$usage_repo"
else
  TARGET_DIR="${PROJECT_DIR:-${CALLER_PWD:-.}}"
  REPO=$("$SCRIPT_DIR/../_get-repo-slug" "$TARGET_DIR")
fi

WORKFLOW="${usage_workflow}"
TIMEOUT="${usage_timeout:-120}"
INTERVAL="${CI_DISPATCH_POLL_INTERVAL:-2}"
CREATED_AT_GRACE="${CI_DISPATCH_CREATED_AT_GRACE:-5}"
GH_BIN="${GH_BIN:-gh}"

# Build input flags (-f key=value) from positional args.
# usage_inputs is a shell-escaped string (e.g., "'message=hello world' 'model=opus'").
INPUT_FLAGS=()
if [[ -n "${usage_inputs:-}" ]]; then
  parse_shell_words "${usage_inputs}"
  for kv in "${PARSED_WORDS[@]}"; do
    INPUT_FLAGS+=(-f "$kv")
  done
fi

# Record timestamp just before dispatch (for filtering). Give GitHub a small
# grace window for timestamp rounding and minor local/API clock skew.
BEFORE=$(($(date +%s) - CREATED_AT_GRACE))

# Dispatch the workflow
"$GH_BIN" workflow run "$WORKFLOW" -R "$REPO" "${INPUT_FLAGS[@]}"

# Poll for the run ID — filter by workflow + created after dispatch.
POLL_START=$(date +%s)
RUN_ID=""
RUN_INFO=""

while [[ -z "$RUN_ID" ]]; do
  # Poll once immediately before sleeping; GitHub usually indexes fast, and
  # this avoids a pointless initial delay on the happy path. Do not use
  # `gh run list --user`: it can omit freshly-dispatched workflow_dispatch runs
  # even when the raw Actions API reports the expected actor/triggering_actor.
  # Workflow + created-after-dispatch is the stable match.
  RUN_INFO=$("$GH_BIN" run list -R "$REPO" --workflow="$WORKFLOW" --limit 5 \
    --json databaseId,createdAt,url 2>/dev/null) || RUN_INFO=""

  if [[ -n "$RUN_INFO" ]]; then
    # Find a run created after our dispatch timestamp.
    # jq's fromdateiso8601 chokes on fractional seconds (e.g., "2026-04-13T21:05:55.024Z"),
    # so we strip them with sub() before parsing.
    # jq yields empty string on no-match and can fail on malformed input; either
    # outcome leaves RUN_ID empty, which causes the while loop to iterate again.
    RUN_ID=$(echo "$RUN_INFO" | jq -r --arg before "$BEFORE" '
      [.[] | select((.createdAt | sub("\\.[0-9]+Z$"; "Z") | fromdateiso8601) >= ($before | tonumber))][0].databaseId // empty
    ' 2>/dev/null) || RUN_ID=""
  fi

  if [[ -n "$RUN_ID" ]]; then
    break
  fi

  NOW=$(date +%s)
  ELAPSED=$((NOW - POLL_START))
  if [[ "$ELAPSED" -ge "$TIMEOUT" ]]; then
    break
  fi

  REMAINING=$((TIMEOUT - ELAPSED))
  SLEEP_FOR="$INTERVAL"
  if [[ "$REMAINING" -lt "$SLEEP_FOR" ]]; then
    SLEEP_FOR="$REMAINING"
  fi
  if [[ "$SLEEP_FOR" -gt 0 ]]; then
    sleep "$SLEEP_FOR"
  fi
done

if [[ -z "$RUN_ID" ]]; then
  echo "Error: workflow was dispatched, but no matching run appeared within ${TIMEOUT}s" >&2
  echo "Check: https://github.com/$REPO/actions/workflows/$WORKFLOW" >&2
  echo "Or list recent runs: gh run list --repo '$REPO' --workflow '$WORKFLOW' --limit 5" >&2
  exit 1
fi

# RUN_URL is used only for the human-friendly stderr message below; the run ID
# has already been determined. Empty on jq failure degrades to "no URL shown".
RUN_URL=$(echo "$RUN_INFO" | jq -r --arg id "$RUN_ID" '.[] | select(.databaseId == ($id | tonumber)) | .url // empty' 2>/dev/null) || RUN_URL=""

# Output run ID (for composability with ci:wait, ci:logs, etc.)
echo "$RUN_ID"

# Human-friendly info on stderr
echo "✓ Dispatched $WORKFLOW (run $RUN_ID)" >&2
if [[ -n "$RUN_URL" ]]; then
  echo "  → $RUN_URL" >&2
fi
