#!/usr/bin/env bash
#MISE description="Shared key registry for secret providers"
#MISE hide=true
# Source this file to get key→1Password item/field mappings.
#
# Usage:
#   source "$(dirname "${BASH_SOURCE[0]}")/_secret-keys"
#   resolve_key "github-pat"
#   echo "$OP_ITEM_SUFFIX $OP_FIELD_GET $OP_FIELD_SET"
#
# After resolve_key, these variables are set:
#   OP_ITEM_SUFFIX  — 1Password item suffix (e.g., "GitHub")
#   OP_FIELD_GET    — field name for `op item get` (e.g., "PAT")
#   OP_FIELD_SET    — field name with type annotation for `op item edit/create` (e.g., "PAT[password]")
#   OP_ITEM_CATEGORY — 1Password item category for `op item create` (e.g., "login", "secure-note")

# Canonical list of all known secret keys.
# Add new keys here — this is the single source of truth.
KNOWN_SECRET_KEYS=(
  github-pat
  github-password
  gpg-private-key
  gpg-public-key
  gpg-key-id
  gpg-fingerprint
  email-password
  matrix-password
  passphrase
  b2-key-id
  b2-application-key
  b2-bucket
  b2-endpoint
)

# Resolve a key name to 1Password item/field coordinates.
# Sets: OP_ITEM_SUFFIX, OP_FIELD_GET, OP_FIELD_SET, OP_ITEM_CATEGORY
# Returns 1 if key is unknown.
resolve_key() {
  local key="$1"
  case "$key" in
    github-pat)
      OP_ITEM_SUFFIX="GitHub";   OP_FIELD_GET="PAT";         OP_FIELD_SET="PAT[password]";         OP_ITEM_CATEGORY="login" ;;
    github-password)
      OP_ITEM_SUFFIX="GitHub";   OP_FIELD_GET="password";    OP_FIELD_SET="password";              OP_ITEM_CATEGORY="login" ;;
    gpg-private-key)
      OP_ITEM_SUFFIX="GPG";     OP_FIELD_GET="Private Key"; OP_FIELD_SET="Private Key[text]";     OP_ITEM_CATEGORY="secure-note" ;;
    gpg-public-key)
      OP_ITEM_SUFFIX="GPG";     OP_FIELD_GET="Public Key";  OP_FIELD_SET="Public Key[text]";      OP_ITEM_CATEGORY="secure-note" ;;
    gpg-key-id)
      OP_ITEM_SUFFIX="GPG";     OP_FIELD_GET="Key ID";      OP_FIELD_SET="Key ID[text]";          OP_ITEM_CATEGORY="secure-note" ;;
    gpg-fingerprint)
      OP_ITEM_SUFFIX="GPG";     OP_FIELD_GET="Fingerprint"; OP_FIELD_SET="Fingerprint[text]";     OP_ITEM_CATEGORY="secure-note" ;;
    email-password)
      OP_ITEM_SUFFIX="Email";   OP_FIELD_GET="password";    OP_FIELD_SET="password";              OP_ITEM_CATEGORY="login" ;;
    matrix-password)
      OP_ITEM_SUFFIX="Matrix";  OP_FIELD_GET="password";    OP_FIELD_SET="password";              OP_ITEM_CATEGORY="login" ;;
    passphrase)
      OP_ITEM_SUFFIX="Identity"; OP_FIELD_GET="passphrase"; OP_FIELD_SET="passphrase[password]";  OP_ITEM_CATEGORY="login" ;;
    b2-key-id)
      OP_ITEM_SUFFIX="B2";      OP_FIELD_GET="Key ID";          OP_FIELD_SET="Key ID[text]";          OP_ITEM_CATEGORY="login" ;;
    b2-application-key)
      OP_ITEM_SUFFIX="B2";      OP_FIELD_GET="Application Key"; OP_FIELD_SET="Application Key[password]"; OP_ITEM_CATEGORY="login" ;;
    b2-bucket)
      OP_ITEM_SUFFIX="B2";      OP_FIELD_GET="Bucket";          OP_FIELD_SET="Bucket[text]";          OP_ITEM_CATEGORY="login" ;;
    b2-endpoint)
      OP_ITEM_SUFFIX="B2";      OP_FIELD_GET="Endpoint";        OP_FIELD_SET="Endpoint[text]";        OP_ITEM_CATEGORY="login" ;;
    *)
      return 1
      ;;
  esac
}

# Print the known keys list (for error messages and secret:list)
print_known_keys() {
  local IFS=', '
  echo "${KNOWN_SECRET_KEYS[*]}"
}
